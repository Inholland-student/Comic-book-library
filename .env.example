# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=comic_user
DB_PASSWORD=your_secure_password_here
DB_NAME=comic_library

# JWT Configuration
JWT_SECRET=your_long_random_secret_key_at_least_32_characters_here

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your_flask_secret_key_here

# MySQL Root (for initial setup only)
MYSQL_ROOT_PASSWORD=root_password_change_me

# ============================================================================
# GITHUB ACTIONS: CONTAINER REGISTRY & SBOM/COSIGN CONFIGURATION
# ============================================================================
# See SBOM-SETUP.md for detailed configuration instructions

# Container Registry (ghcr.io, docker.io, or your private registry)
REGISTRY=ghcr.io

# Registry credentials (stored as GitHub Secrets, not in code)
# REGISTRY_USERNAME=your_username
# REGISTRY_PASSWORD=your_password_or_token

# Image names (relative to registry)
FRONTEND_IMAGE_NAME=meryamdouiri/comic-book-library/frontend
BACKEND_IMAGE_NAME=meryamdouiri/comic-book-library/backend

# Tool versions
SYFT_VERSION=v0.105.0
COSIGN_VERSION=v2.2.2

# Local development
LOCAL_FRONTEND_IMAGE=comic-frontend:latest
LOCAL_BACKEND_IMAGE=comic-backend:latest
SBOM_OUTPUT_DIR=./sbom-reports
