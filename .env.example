# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=comic_user
DB_PASSWORD=your_secure_password_here
DB_NAME=comic_library

# JWT Configuration
JWT_SECRET=your_long_random_secret_key_at_least_32_characters_here

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your_flask_secret_key_here

# MySQL Root (for initial setup only)
MYSQL_ROOT_PASSWORD=root_password_change_me
